        "jsScript" : "return {msg: msg, metadata: metadata, msgType: msgType};",
        "tbelScript" : "var out = {};\r\nforeach (entry : msg.entrySet()) {\r\n    var k = entry.key;\r\n    var v = entry.value;\r\n    if (k.startsWith(\"data_\")) {\r\n        var clean = k.substring(5);\r\n        if (out.get(clean) == null && msg.get(clean) == null) {\r\n            out[clean] = v;\r\n        } else {\r\n            out[\"_collision_\" + clean] = v;\r\n        }\r\n    } else {\r\n        out[k] = v;\r\n    }\r\n}\r\nreturn {msg: out, metadata: metadata, msgType: msgType};"
